{
  "name": "nexuspanel",
  "version": "3.0.0",
  "description": "Lightweight Minecraft server panel with SQLite accounts and admin permissions.",
  "main": "backend/index.js",
  "bin": {
    "nexuspanel": "backend/cli.js"
  },
  "scripts": {
    "start": "node backend/launcher.js",
    "foreground": "node backend/index.js",
    "dev": "node --watch backend/index.js",
    "service:install": "node backend/service.js install",
    "service:uninstall": "node backend/service.js uninstall",
    "service:status": "node backend/service.js status",
    "service:logs": "journalctl -u nexuspanel -f",
    "cli": "node backend/cli.js",
    "update": "bash update/update.sh",
    "test": "npm run test:auth && npm run test:v3 && npm run test:nexusmark",
    "test:auth": "node tests/auth.test.js",
    "test:v3": "node tests/v3.test.js",
    "test-auth": "npm run test:auth",
    "debug-users": "node scripts/debug-users.js",
    "reset-password": "node scripts/reset-password.js",
    "build:nexusmark": "node backend/nexus_mark_native.js",
    "build:host-agent": "node backend/host_agent.js",
    "test:nexusmark": "bash native/nexusmark/tests/test.sh",
    "audit:nexusmark": "sudo bash native/nexusmark/tests/test-audit.sh",
    "benchmark:nexusmark": "bash native/nexusmark/tests/benchmark.sh"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "node-pty": "^1.1.0"
  }
}
