{
  "name": "nexuspanel",
  "version": "2.0.0",
  "description": "Lightweight Minecraft server panel with SQLite accounts and admin permissions.",
  "main": "backend/index.js",
  "bin": {
    "nexuspanel": "backend/cli.js"
  },
  "scripts": {
    "start": "node backend/launcher.js",
    "foreground": "node backend/index.js",
    "dev": "node --watch backend/index.js",
    "service:install": "node backend/service.js install",
    "service:uninstall": "node backend/service.js uninstall",
    "service:status": "node backend/service.js status",
    "service:logs": "journalctl -u nexuspanel -f",
    "cli": "node backend/cli.js",
    "update": "bash update/update.sh",
    "test-auth": "node backend/test-auth.js",
    "debug-users": "node backend/debug-users.js",
    "reset-password": "node backend/reset-password.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "express": "^4.18.2"
  },
  "optionalDependencies": {
    "bedrock-protocol": "^3.43.0",
    "mineflayer": "^4.32.0",
    "node-pty": "^1.1.0"
  }
}
